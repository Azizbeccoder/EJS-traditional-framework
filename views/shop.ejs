<%- include('header') %>

<div class="shop-container">
    <h1>Shopping Page</h1>
    
    <!-- Add Item Form -->
    <div class="form-section">
        <h2>Add New Item</h2>
        <form method="POST" action="/add-item" class="add-item-form">
            <div class="form-group">
                <label for="itemName">Item Name:</label>
                <input type="text" id="itemName" name="itemName" required placeholder="Enter item name">
            </div>
            <div class="form-group">
                <label for="itemPrice">Price:</label>
                <input type="number" id="itemPrice" name="itemPrice" step="0.01" required placeholder="Enter price">
            </div>
            <button type="submit" class="btn btn-success">Add Item</button>
        </form>
    </div>

    <!-- Items List -->
    <div class="items-section">
        <h2>Items (<%= items.length %>)</h2>
        
        <% if (items.length > 0) { %>
            <div class="items-grid">
                <% items.forEach(item => { %>
                    <div class="item-card">
                        <div class="item-header">
                            <h3><%= item.name %></h3>
                            <span class="price">$<%= parseFloat(item.price).toFixed(2) %></span>
                        </div>
                        <p class="item-date">Added: <%= item.date %></p>
                        <a href="/delete/<%= item.id %>" class="btn btn-danger btn-small" onclick="return confirm('Delete this item?');">Delete</a>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="empty-state">
                <p>No items yet. Add one above!</p>
            </div>
        <% } %>
    </div>
</div>

<%- include('footer') %>
