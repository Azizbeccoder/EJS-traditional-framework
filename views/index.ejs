<%- include('header') %>

<div class="hero">
    <h1>Welcome to EJS Framework</h1>
    <p>A modern web application built with Express.js and EJS templating</p>
    <a href="/shop" class="btn btn-primary">Start Shopping</a>
</div>

<div class="stats">
    <div class="stat-card">
        <h3><%= itemCount %></h3>
        <p>Total Items</p>
    </div>
    <div class="stat-card">
        <h3>Express</h3>
        <p>Web Framework</p>
    </div>
    <div class="stat-card">
        <h3>EJS</h3>
